{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "rootDir": "..",
    "outDir": "dist",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@game/*": ["../src/game/*"]
    }
  },
  "include": ["**/*.ts", "../src/game/**/*.ts"]
}
